<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="cq:Page">
    <jcr:content
        cq:template="/conf/wknd-spa-react/settings/wcm/templates/xfinity-hub-template"
        jcr:primaryType="cq:PageContent"
        sling:resourceType="wknd-spa-react/components/page">
        <root
            jcr:primaryType="nt:unstructured"
            sling:resourceType="wcm/foundation/components/responsivegrid">
            <responsivegrid
                jcr:primaryType="nt:unstructured"
                sling:resourceType="wcm/foundation/components/responsivegrid">
                <card1
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="wknd-spa-react/components/content-card"
                    category="Internet"
                    description="Lock in your rate for 5 years with Xfinity Internet. Learn more about what this means for you."
                    link="/hub/internet/5-year-price-guarantee"
                    title="What to Know About the New 5 Year Price Guarantee"/>
                <card2
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="wknd-spa-react/components/content-card"
                    category="Entertainment"
                    description="Stream all your favorite MLB games on Xfinity. Find out how to watch this season."
                    link="/hub/tv-video/baseball"
                    title="Where to Watch Major League Baseball this Season"/>
                <card3
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="wknd-spa-react/components/content-card"
                    category="Entertainment"
                    description="Discover the latest streaming releases available on Peacock and Xfinity Entertainment platforms."
                    link="/hub/tv-video/what-to-stream"
                    title="Streaming in April: Peacockfest, 'ted' Season 2 and 'Wicked: For Good'"/>
            </responsivegrid>
        </root>
    </jcr:content>
</jcr:root>
